---
import BaseLayout from '../../layouts/BaseLayout.astro';

const routes = [
  {
    method: 'Shinkansen',
    from: 'Hakata (Fukuoka)',
    time: '1h 20m',
    details: 'Sakura or Mizuho services to Kagoshima-Chuo Station. The fastest and most comfortable option from northern Kyushu.',
    icon: '→',
  },
  {
    method: 'Flight',
    from: 'Tokyo (Haneda /羽田)',
    time: '1h 50m',
    details: 'Multiple daily flights with ANA and JAL. Kagoshima Airport is 30–40 minutes from the city by limousine bus.',
    icon: '↑',
  },
  {
    method: 'Flight',
    from: 'Osaka (Itami / 伊丹)',
    time: '1h 10m',
    details: 'Quicker than the shinkansen for most Osaka travelers. Itami has more Kagoshima flights than Kansai Airport.',
    icon: '↑',
  },
  {
    method: 'Ferry',
    from: 'Osaka',
    time: '15h (overnight)',
    details: 'Marue Ferry runs an overnight service to Kagoshima-Shin-Ko. A slow, scenic option — cabins available.',
    icon: '≈',
  },
];
---

<BaseLayout
  title="Getting There"
  description="How to get to Kagoshima — shinkansen from Hakata, flights from Tokyo and Osaka, and ferry options from Osaka and Okinawa."
  ogType="website"
>
  <section class="page-hero">
    <div class="page-hero__container">
      <p class="eyebrow">Practical info</p>
      <h1 class="page-hero__title">Getting there.</h1>
      <p class="page-hero__lede">
        Kagoshima is at the southern end of the Kyushu Shinkansen line.
        It's closer than most people think.
      </p>
    </div>
  </section>

  <section class="routes">
    <div class="routes__container">
      <p class="eyebrow">Your options</p>
      <div class="routes__list">
        {routes.map((route) => (
          <div class="route-card">
            <div class="route-card__icon" aria-hidden="true">{route.icon}</div>
            <div class="route-card__body">
              <div class="route-card__meta">
                <span class="route-card__method">{route.method}</span>
                <span class="route-card__from">from {route.from}</span>
              </div>
              <div class="route-card__time">{route.time}</div>
              <p class="route-card__details">{route.details}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="tips">
    <div class="tips__container">
      <p class="eyebrow">Tips</p>
      <div class="tips__grid">
        <div class="tip">
          <h3 class="tip__title">JR Pass users</h3>
          <p class="tip__body">
            The Kyushu Shinkansen is covered by the JR Pass and the JR Kyushu Pass.
            Book reserved seats in advance, especially on Mizuho services.
          </p>
        </div>
        <div class="tip">
          <h3 class="tip__title">From the airport</h3>
          <p class="tip__body">
            Limousine buses run every 10–15 minutes to Kagoshima-Chuo Station (250 yen, 40 min).
            Taxis are available but expensive for the distance.
          </p>
        </div>
        <div class="tip">
          <h3 class="tip__title">To the islands</h3>
          <p class="tip__body">
            Ferries and small planes connect Kagoshima City to Yakushima, Amami Oshima,
            and the Satsunan chain. Book in advance for summer travel.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :root {
    --ash-50: #f5f4f1;
    --ash-100: #e8e6e0;
    --ash-300: #b5b1a8;
    --ash-600: #4a4742;
    --ash-900: #1a1816;
    --ember-500: #c14627;
    --steam: #fbfaf7;
    --font-display: 'Fraunces', 'Times New Roman', serif;
    --font-body: 'Plus Jakarta Sans', system-ui, sans-serif;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ember-500);
    margin-bottom: 1rem;
  }

  .page-hero {
    padding: 6rem 2rem 5rem;
    background: var(--ash-900);
    color: var(--steam);
  }

  .page-hero__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--steam);
    margin: 0 0 1.5rem;
  }

  .page-hero__lede {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--ash-300);
    max-width: 600px;
    margin: 0;
  }

  .routes {
    padding: 6rem 2rem;
    background: var(--steam);
  }

  .routes__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .routes__list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin-top: 2rem;
    background: var(--ash-100);
    border: 1px solid var(--ash-100);
  }

  .route-card {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    padding: 2rem 2.5rem;
    background: white;
  }

  .route-card__icon {
    font-size: 1.5rem;
    color: var(--ember-500);
    width: 2rem;
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  .route-card__body { flex: 1; }

  .route-card__meta {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .route-card__method {
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ash-900);
  }

  .route-card__from {
    font-size: 0.875rem;
    color: var(--ash-600);
  }

  .route-card__time {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--ash-900);
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .route-card__details {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--ash-600);
    margin: 0;
  }

  .tips {
    padding: 6rem 2rem;
    background: var(--ash-50);
    border-top: 1px solid var(--ash-100);
  }

  .tips__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .tips__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }

  .tip { padding-top: 1.5rem; border-top: 1px solid var(--ash-300); }

  .tip__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--ash-900);
    margin: 0 0 0.75rem;
  }

  .tip__body {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--ash-600);
    margin: 0;
  }

  @media (max-width: 768px) {
    .route-card { padding: 1.5rem; }
    .tips__grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .page-hero { padding: 4rem 1.5rem 3rem; }
    .routes, .tips { padding: 4rem 1.5rem; }
    .route-card { flex-direction: column; gap: 1rem; }
  }
</style>
