---
import BaseLayout from '../../layouts/BaseLayout.astro';

const routes = [
  {
    method: 'Flight',
    from: 'Tokyo (Haneda / Narita)',
    time: '1h 50m',
    cost: '¥15,000 - ¥40,000',
    details: 'Multiple daily flights with ANA, JAL, Solaseed Air, and Skymark. Kagoshima Airport is 30–40 minutes from the city by limousine bus.',
    image: '/images/airplane.png',
    bestFor: 'Time efficiency',
    icon: '↑',
  },
  {
    method: 'Shinkansen',
    from: 'Osaka (Shin-Osaka)',
    time: '3h 45m',
    cost: '¥22,630',
    details: 'Direct Mizuho or Sakura services to Kagoshima-Chuo Station. A comfortable, scenic ride down the length of western Japan. Covered by JR Pass with a supplement for Mizuho.',
    image: '/images/shinkansen.png',
    bestFor: 'Comfort & JR Pass',
    icon: '→',
  },
  {
    method: 'Flight',
    from: 'Osaka (Itami / Kansai)',
    time: '1h 10m',
    cost: '¥8,000 - ¥30,000',
    details: 'Quicker than the shinkansen for most Osaka travelers. Peach Aviation offers budget flights from Kansai (KIX).',
    image: '/images/airplane.png',
    bestFor: 'Budget (LCC)',
    icon: '↑',
  },
  {
    method: 'Shinkansen',
    from: 'Fukuoka (Hakata)',
    time: '1h 20m',
    cost: '¥10,640',
    details: 'Sakura or Mizuho services. The fastest and most convenient option from northern Kyushu.',
    image: '/images/shinkansen.png',
    bestFor: 'Speed from Kyushu',
    icon: '→',
  },
  {
    method: 'Ferry',
    from: 'Osaka',
    time: '15h',
    cost: 'From ¥14,000',
    details: 'Sunflower Ferry runs an overnight service to Shibushi (Kagoshima), with a connecting bus to Kagoshima City. A slow, relaxing option.',
    image: '/images/ferry.png',
    bestFor: 'Relaxation',
    icon: '≈',
  },
];
---

<BaseLayout
  title="Getting There"
  description="How to get to Kagoshima — shinkansen from Hakata, flights from Tokyo and Osaka, and ferry options from Osaka and Okinawa."
  ogType="website"
>
  <section class="page-hero">
    <div class="page-hero__container">
      <p class="eyebrow">Practical info</p>
      <h1 class="page-hero__title">Getting there.</h1>
      <p class="page-hero__lede">
        Kagoshima is at the southern end of the Kyushu Shinkansen line.
        It's closer than most people think.
      </p>
    </div>
  </section>

  <section class="routes">
    <div class="routes__container">
      <p class="eyebrow">Your options</p>
      <div class="routes__list">
        {routes.map((route) => (
          <div class="route-card">
            <div class="route-card__visual">
              <img src={route.image} alt="" class="route-card__image" loading="lazy" />
              <div class="route-card__best-for">{route.bestFor}</div>
            </div>
            <div class="route-card__body">
              <div class="route-card__header">
                <div class="route-card__icon" aria-hidden="true">{route.icon}</div>
                <div class="route-card__meta">
                  <span class="route-card__method">{route.method}</span>
                  <span class="route-card__from">from {route.from}</span>
                </div>
              </div>
              <div class="route-card__stats">
                <div class="route-card__stat">
                  <span class="route-card__stat-label">Time</span>
                  <span class="route-card__time">{route.time}</span>
                </div>
                <div class="route-card__stat">
                  <span class="route-card__stat-label">Est. Cost</span>
                  <span class="route-card__cost">{route.cost}</span>
                </div>
              </div>
              <p class="route-card__details">{route.details}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="tips">
    <div class="tips__container">
      <p class="eyebrow">Tips</p>
      <div class="tips__grid">
        <div class="tip">
          <h3 class="tip__title">JR Pass users</h3>
          <p class="tip__body">
            The Kyushu Shinkansen is covered by the JR Pass and the JR Kyushu Pass.
            Book reserved seats in advance, especially on Mizuho services.
          </p>
        </div>
        <div class="tip">
          <h3 class="tip__title">From the airport</h3>
          <p class="tip__body">
            Limousine buses run every 10–15 minutes to Kagoshima-Chuo Station (250 yen, 40 min).
            Taxis are available but expensive for the distance.
          </p>
        </div>
        <div class="tip">
          <h3 class="tip__title">To the islands</h3>
          <p class="tip__body">
            Ferries and small planes connect Kagoshima City to Yakushima, Amami Oshima,
            and the Satsunan chain. Book in advance for summer travel.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :root {
    --ash-50: #f5f4f1;
    --ash-100: #e8e6e0;
    --ash-300: #b5b1a8;
    --ash-600: #4a4742;
    --ash-900: #1a1816;
    --ember-500: #c14627;
    --steam: #fbfaf7;
    --font-display: 'Fraunces', 'Times New Roman', serif;
    --font-body: 'Plus Jakarta Sans', system-ui, sans-serif;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ember-500);
    margin-bottom: 1rem;
  }

  .page-hero {
    padding: 6rem 2rem 5rem;
    background: var(--ash-900);
    color: var(--steam);
  }

  .page-hero__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--steam);
    margin: 0 0 1.5rem;
  }

  .page-hero__lede {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--ash-300);
    max-width: 600px;
    margin: 0;
  }

  .routes {
    padding: 6rem 2rem;
    background: var(--steam);
  }

  .routes__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .routes__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-top: 3rem;
  }

  .route-card {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 3rem;
    background: white;
    border: 1px solid var(--ash-100);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .route-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.05);
  }

  .route-card__visual {
    position: relative;
    height: 100%;
    min-height: 250px;
    background: var(--ash-50);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .route-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .route-card:hover .route-card__image {
    transform: scale(1.05);
  }

  .route-card__best-for {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    background: var(--ash-900);
    color: var(--steam);
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .route-card__body { 
    padding: 2.5rem 3rem 2.5rem 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .route-card__header {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .route-card__icon {
    font-size: 1.75rem;
    color: var(--ember-500);
    line-height: 1;
    margin-top: 0.1rem;
  }

  .route-card__meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .route-card__method {
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ember-500);
  }

  .route-card__from {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--ash-900);
    line-height: 1.2;
  }

  .route-card__stats {
    display: flex;
    gap: 4rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--ash-100);
  }

  .route-card__stat {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .route-card__stat-label {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ash-600);
  }

  .route-card__time, .route-card__cost {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 300;
    color: var(--ash-900);
    line-height: 1;
  }

  .route-card__details {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ash-600);
    margin: 0;
  }

  .tips {
    padding: 6rem 2rem;
    background: var(--ash-50);
    border-top: 1px solid var(--ash-100);
  }

  .tips__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .tips__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }

  .tip { padding-top: 1.5rem; border-top: 1px solid var(--ash-300); }

  .tip__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--ash-900);
    margin: 0 0 0.75rem;
  }

  .tip__body {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--ash-600);
    margin: 0;
  }

  @media (max-width: 900px) {
    .route-card {
      grid-template-columns: 1fr;
    }
    .route-card__visual {
      min-height: 300px;
    }
    .route-card__body {
      padding: 2.5rem;
    }
    .route-card__stats {
      flex-wrap: wrap;
      gap: 2rem;
    }
  }

  @media (max-width: 768px) {
    .route-card { padding: 1.5rem; }
    .tips__grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .page-hero { padding: 4rem 1.5rem 3rem; }
    .routes, .tips { padding: 4rem 1.5rem; }
    .route-card__body { padding: 1.5rem; }
    .route-card__time, .route-card__cost { font-size: 1.5rem; }
  }
</style>
