---
import BaseLayout from '../layouts/BaseLayout.astro';
import AccessComparison from '../components/AccessComparison.astro';
import { getCollection } from 'astro:content';

async function getFeaturedArticle(collectionName: 'places' | 'food' | 'itineraries') {
  const articles = await getCollection(collectionName, ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });
  return articles.sort(
    (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
  )[0];
}

const featuredPlace = await getFeaturedArticle('places');
const featuredFood = await getFeaturedArticle('food');
const featuredItinerary = await getFeaturedArticle('itineraries');

const homeStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'TravelGuide',
  name: 'Kagoshima Travel Guide: Access & Transit',
  description:
    'Discover how easy it is to reach Kagoshima. Only a 1h 50m flight from Tokyo to explore active volcanoes, UNESCO forests, and sand baths.',
  about: {
    '@type': 'Place',
    name: 'Kagoshima',
    address: {
      '@type': 'PostalAddress',
      addressRegion: 'Kagoshima Prefecture',
      addressCountry: 'JP',
    },
  },
};
---

<BaseLayout
  title="Closer Than You Think: Kagoshima Travel Guide"
  description="Don't let the map fool you. Kagoshima's active volcanoes and subtropical islands are just a quick flight away from Tokyo or Osaka."
  ogType="website"
  structuredData={homeStructuredData}
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero__grid">
      <div class="hero__copy">
        <p class="hero__eyebrow">A guide to reaching Japan's untamed south</p>
        <h1 class="hero__title">
          Closer than
          <span class="hero__title-accent">you think.</span>
        </h1>
        <p class="hero__lede">
          Don't let the map fool you. Japan's most spectacular volcanic landscapes and subtropical islands aren't days away—they are just a quick morning flight from Tokyo. Leave the Golden Route behind and step into the wild south by noon.
        </p>
        <div class="hero__actions">
          <a href="#getting-here" class="btn btn--primary">View Access Options</a>
          <a href="#destinations" class="btn btn--ghost">Travel Times</a>
        </div>
      </div>

      <div class="hero__visual">
        <div class="hero__photo hero__photo--main" aria-hidden="true">
          <span class="hero__photo-label">Sakurajima Volcano</span>
        </div>
        <div class="hero__photo hero__photo--accent" aria-hidden="true">
          <span class="hero__photo-label">Kagoshima Airport</span>
        </div>
        <div class="hero__metric">
          <span class="hero__metric-num">110</span>
          <span class="hero__metric-label">minutes flight from Tokyo</span>
        </div>
      </div>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <span>Scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <!-- ACCESS COMPARISON -->
  <section id="getting-here" class="access-section">
    <div class="access-section__container">
      <p class="section-eyebrow">Getting to Kagoshima</p>
      <h2 class="section-title">Skip the long train ride.</h2>
      <p class="section-lede">
        Many travelers assume Kagoshima requires a multi-day train journey. In reality, multiple budget airlines (LCCs) connect Tokyo and Osaka directly to Kagoshima daily.
      </p>
      
      <AccessComparison />
      
    </div>
  </section>

  <!-- DESTINATIONS BY TIME -->
  <section id="destinations" class="transit-times">
    <div class="transit-times__container">
      <div class="transit-times__intro">
        <p class="section-eyebrow">From Basecamp to Adventure</p>
        <h2 class="section-title">Your transit times from Kagoshima City.</h2>
        <p class="transit-times__lede">
          Once you arrive at Kagoshima-Chuo Station, the prefecture's best sights are surprisingly accessible. Here is how long it takes to reach the highlights.
        </p>
      </div>

      <div class="transit-cards">
        <a href="/places/sakurajima/" class="transit-card transit-card--01">
          <div class="transit-card__header">
            <span class="transit-card__time">40 mins</span>
            <span class="transit-card__mode">Tram + Ferry</span>
          </div>
          <h3 class="transit-card__name">Sakurajima Volcano</h3>
          <p class="transit-card__desc">Hop on a city tram to the port, then a 15-minute ferry that runs 24/7 across the bay.</p>
        </a>
        <a href="/places/ibusuki/" class="transit-card transit-card--02">
          <div class="transit-card__header">
            <span class="transit-card__time">50 mins</span>
            <span class="transit-card__mode">Express Train</span>
          </div>
          <h3 class="transit-card__name">Ibusuki Sand Baths</h3>
          <p class="transit-card__desc">Ride the scenic "Ibusuki no Tamatebako" limited express train directly down the coast.</p>
        </a>
        <a href="/places/kirishima/" class="transit-card transit-card--03">
          <div class="transit-card__header">
            <span class="transit-card__time">55 mins</span>
            <span class="transit-card__mode">Train / Bus</span>
          </div>
          <h3 class="transit-card__name">Kirishima Hot Springs</h3>
          <p class="transit-card__desc">A quick train ride north into the mountains for ancient shrines and volcanic onsen.</p>
        </a>
        <a href="/places/yakushima/" class="transit-card transit-card--04">
          <div class="transit-card__header">
            <span class="transit-card__time">1h 50m</span>
            <span class="transit-card__mode">High-speed Jetfoil</span>
          </div>
          <h3 class="transit-card__name">Yakushima (UNESCO)</h3>
          <p class="transit-card__desc">Departing from Kagoshima Port, the Toppy Jetfoil cuts across the sea to the ancient cedar forests.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- TIME-OPTIMIZED ITINERARIES -->
  <section class="itineraries-feature">
    <div class="itineraries-feature__container">
      <div class="itineraries-feature__header">
        <p class="section-eyebrow">Maximize your time</p>
        <h2 class="section-title">Time-optimized trip plans.</h2>
      </div>
      <ul class="itineraries-feature__list">
        <li class="itin-card itin-card--featured">
          <a href="/itineraries/" class="itin-card__link">
            <div class="itin-card__duration">
              <span class="itin-card__num">48</span>
              <span class="itin-card__unit">hours</span>
            </div>
            <h3 class="itin-card__title">The Weekend Dash</h3>
            <p class="itin-card__desc">
              Fly in Saturday morning, see the volcano, eat black pork, soak in hot sand, and fly back Sunday night.
            </p>
            <span class="itin-card__cta">See the schedule →</span>
          </a>
        </li>
        <li class="itin-card">
          <a href="/itineraries/" class="itin-card__link">
            <div class="itin-card__duration">
              <span class="itin-card__num">3</span>
              <span class="itin-card__unit">days</span>
            </div>
            <h3 class="itin-card__title">The Rental Car Loop</h3>
            <p class="itin-card__desc">Grab a car at the airport to efficiently cover Kirishima, the city, and the southern peninsula.</p>
            <span class="itin-card__cta">Coming soon</span>
          </a>
        </li>
        <li class="itin-card">
          <a href="/itineraries/" class="itin-card__link">
            <div class="itin-card__duration">
              <span class="itin-card__num">4</span>
              <span class="itin-card__unit">days</span>
            </div>
            <h3 class="itin-card__title">City + Yakushima</h3>
            <p class="itin-card__desc">Perfectly timed transfers to catch the jetfoil, hike the forests, and return to the mainland.</p>
            <span class="itin-card__cta">Coming soon</span>
          </a>
        </li>
      </ul>
    </div>
  </section>

</BaseLayout>

<style>
  /* DESIGN TOKENS */
  :root {
    --ash-50: #f5f4f1;
    --ash-100: #e8e6e0;
    --ash-300: #b5b1a8;
    --ash-600: #4a4742;
    --ash-900: #1a1816;

    --indigo-50: #eef1f5;
    --indigo-500: #2a4a6e;
    --indigo-700: #1a3354;
    --indigo-900: #0d1e35;

    --ember-500: #c14627;
    --ember-700: #8a2f1a;

    --steam: #fbfaf7;
    --moss-500: #4a6b3a;

    --font-display: 'Fraunces', 'Times New Roman', serif;
    --font-body: 'Plus Jakarta Sans', system-ui, sans-serif;
  }

  :global(body) {
    background: var(--steam);
    color: var(--ash-900);
    font-family: var(--font-body);
  }

  /* Common section styles */
  .section-eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ember-500);
    margin-bottom: 1rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ash-900);
    margin: 0 0 2rem;
    max-width: 24ch;
  }
  
  .section-lede {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--ash-600);
    max-width: 800px;
    margin-bottom: 3rem;
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 0.875rem 2rem;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    border: 1.5px solid transparent;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .btn--primary {
    background: var(--ash-900);
    color: var(--steam);
    border-color: var(--ash-900);
  }

  .btn--primary:hover {
    background: var(--indigo-700);
    border-color: var(--indigo-700);
    transform: translateY(-1px);
  }

  .btn--ghost {
    background: transparent;
    color: var(--ash-900);
    border-color: var(--ash-900);
  }

  .btn--ghost:hover {
    background: var(--ash-900);
    color: var(--steam);
  }

  /* HERO */
  .hero {
    position: relative;
    min-height: calc(100vh - 80px);
    padding: 4rem 2rem 6rem;
    background: var(--steam);
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 40%;
    height: 100%;
    background: linear-gradient(135deg, transparent 0%, var(--ash-50) 100%);
    pointer-events: none;
    z-index: 0;
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    min-height: calc(100vh - 200px);
  }

  .hero__copy { max-width: 560px; }

  .hero__eyebrow {
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--ember-500);
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--ash-300);
    display: inline-block;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ash-900);
    margin: 0 0 2rem;
  }

  .hero__title-accent {
    display: block;
    font-style: italic;
    font-weight: 400;
    color: var(--indigo-700);
  }

  .hero__lede {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--ash-600);
    margin-bottom: 2.5rem;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero__visual {
    position: relative;
    height: 600px;
  }

  .hero__photo {
    position: absolute;
    background: var(--ash-100);
    overflow: hidden;
  }

  .hero__photo--main {
    top: 0;
    right: 0;
    width: 80%;
    height: 70%;
    background: linear-gradient(135deg, var(--ash-300) 0%, var(--ash-600) 100%);
  }

  .hero__photo--main::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 30% 70%, rgba(193, 70, 39, 0.4) 0%, transparent 50%),
      radial-gradient(circle at 70% 30%, rgba(255, 255, 255, 0.2) 0%, transparent 40%);
  }

  .hero__photo--accent {
    bottom: 0;
    left: 0;
    width: 60%;
    height: 50%;
    background: linear-gradient(135deg, var(--moss-500) 0%, var(--indigo-700) 100%);
  }

  .hero__photo-label {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    font-size: 0.75rem;
    color: var(--steam);
    font-family: var(--font-body);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  .hero__metric {
    position: absolute;
    top: 50%;
    left: -2rem;
    transform: translateY(-50%);
    background: var(--steam);
    padding: 1.5rem 2rem;
    border: 1px solid var(--ash-300);
    z-index: 2;
    box-shadow: -8px 8px 0 var(--indigo-500);
  }

  .hero__metric-num {
    display: block;
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 400;
    color: var(--indigo-700);
    line-height: 1;
  }

  .hero__metric-label {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ash-600);
  }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ash-600);
  }

  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: var(--ash-300);
    position: relative;
    overflow: hidden;
  }

  .hero__scroll-line::after {
    content: '';
    position: absolute;
    top: -40px;
    left: 0;
    width: 100%;
    height: 40px;
    background: var(--ash-900);
    animation: scroll-down 2s ease-in-out infinite;
  }

  @keyframes scroll-down {
    0% { transform: translateY(0); }
    100% { transform: translateY(80px); }
  }

  /* ACCESS SECTION */
  .access-section {
    padding: 8rem 2rem;
    background: var(--ash-900);
    color: var(--steam);
  }

  .access-section__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .access-section .section-eyebrow { color: var(--ember-500); }
  .access-section .section-title {
    color: var(--steam);
    margin-bottom: 2rem;
  }
  .access-section .section-lede {
    color: var(--ash-300);
  }

  /* TRANSIT TIMES */
  .transit-times {
    padding: 8rem 2rem;
    background: var(--steam);
  }

  .transit-times__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .transit-times__intro {
    max-width: 700px;
    margin-bottom: 4rem;
  }

  .transit-times__lede {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--ash-600);
  }

  .transit-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .transit-card {
    display: block;
    padding: 2.5rem 2rem;
    background: var(--ash-50);
    text-decoration: none;
    color: var(--ash-900);
    border: 1px solid transparent;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .transit-card:hover {
    border-color: var(--ember-500);
    transform: translateY(-2px);
    background: white;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .transit-card__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--ash-100);
    padding-bottom: 1rem;
  }

  .transit-card__time {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--ember-500);
    line-height: 1;
  }

  .transit-card__mode {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ash-600);
    background: var(--ash-100);
    padding: 4px 10px;
    border-radius: 4px;
  }

  .transit-card__name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    margin: 0 0 1rem;
    color: var(--ash-900);
  }

  .transit-card__desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--ash-600);
    margin: 0;
  }

  /* ITINERARIES */
  .itineraries-feature {
    padding: 8rem 2rem;
    background: var(--indigo-900);
    color: var(--steam);
  }

  .itineraries-feature__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .itineraries-feature__header {
    margin-bottom: 4rem;
  }

  .itineraries-feature .section-eyebrow { color: var(--ember-500); }
  .itineraries-feature .section-title { color: var(--steam); }

  .itineraries-feature__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 1.5rem;
  }

  .itin-card {
    background: var(--indigo-700);
    transition: all 0.3s;
  }

  .itin-card--featured {
    background: var(--steam);
    color: var(--ash-900);
  }

  .itin-card:hover { transform: translateY(-4px); }

  .itin-card__link {
    display: block;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .itin-card__duration {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .itin-card__num {
    font-family: var(--font-display);
    font-size: 4rem;
    font-weight: 300;
    line-height: 1;
    color: var(--ember-500);
  }

  .itin-card--featured .itin-card__num {
    color: var(--ember-700);
  }

  .itin-card__unit {
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: inherit;
    opacity: 0.7;
  }

  .itin-card__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1.2;
    margin: 0 0 1rem;
  }

  .itin-card__desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    opacity: 0.8;
    margin-bottom: 1.5rem;
  }

  .itin-card__cta {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ember-500);
  }

  .itin-card--featured .itin-card__cta {
    color: var(--ember-700);
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .hero__grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .hero__visual {
      height: 400px;
      order: 2;
    }
    .transit-cards { grid-template-columns: 1fr; }
    .itineraries-feature__list { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .hero { padding: 3rem 1.5rem 4rem; }
    .hero__title { font-size: clamp(2.5rem, 10vw, 3.5rem); }

    .access-section,
    .transit-times,
    .itineraries-feature {
      padding: 5rem 1.5rem;
    }

    .hero__metric {
      left: 1rem;
      padding: 1rem 1.5rem;
    }
    .hero__metric-num { font-size: 2rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-line::after { animation: none; }
  }
</style>
